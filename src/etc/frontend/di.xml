<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Checkout\Controller\Index\Index">
        <plugin name="FriendsOfHyva_ReactCheckout::forward_checkout_to_reactcheckout"
                type="FriendsOfHyva\ReactCheckout\Plugin\CheckoutController\ForwardCheckoutToReactCheckout"/>
    </type>
    <type name="Magento\Customer\Controller\Ajax\Login">
        <arguments>
            <argument name="resultJsonFactory"
                      xsi:type="object">FriendsOfHyva\ReactCheckout\Result\JsonFactory</argument>
        </arguments>
        <plugin name="FriendsOfHyva_ReactCheckout::ajax_login"
                type="FriendsOfHyva\ReactCheckout\Plugin\CustomerController\AjaxLogin" />
    </type>
</config>
