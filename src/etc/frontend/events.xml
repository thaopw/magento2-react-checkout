<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="hyva_config_generate_before">
        <observer
            name="FriendsOfHyva_ReactCheckout::register_module_in_hyva_config"
            instance="FriendsOfHyva\ReactCheckout\Observer\RegisterModuleForHyvaConfig"/>
    </event>
    <event name="hyva_react_checkout_config">
        <observer
            name="FriendsOfHyva_ReactCheckout::add_cart_info_to_checkout_config"
            instance="FriendsOfHyva\ReactCheckout\Observer\AddCartInfoInCheckoutConfig"/>
    </event>
</config>
